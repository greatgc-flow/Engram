# Line ending policy
# bat/ps1 files MUST be CRLF on Windows — LF causes CMD.exe parsing failures (setlocal -> tlocal)
*.bat    text eol=crlf
*.ps1    text eol=crlf
*.cmd    text eol=crlf

# Text files: LF
*.md     text eol=lf
*.json   text eol=lf
*.txt    text eol=lf
*.sh     text eol=lf

# Binary
*.exe    binary
*.zip    binary
*.png    binary
*.jpg    binary
