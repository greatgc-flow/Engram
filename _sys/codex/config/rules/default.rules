prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$files = Get-ChildItem -LiteralPath 'P:\\' -File -Force | Where-Object { $_.Name -match '^[a-z0-9_]{8}$' -and $_.Length -eq 4 -and $_.CreationTime -ge [datetime]'2026-06-21T17:55:00' -and (Get-Content -LiteralPath $_.FullName -Raw) -eq 'blat' }; $files | Remove-Item -Force; \"removed=$($files.Count)\""], decision="allow")
prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$files = Get-ChildItem -LiteralPath 'P:\\' -File -Force | Where-Object { $_.Name -match '^[a-z0-9_]{8}$' -and $_.Length -eq 4 -and $_.CreationTime -ge [datetime]'2026-06-21T17:55:00' -and (Get-Content -LiteralPath $_.FullName -Raw) -eq 'blat' }; $files | Remove-Item -Force -ErrorAction Stop; \"removed=$($files.Count)\""], decision="allow")
prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$target = (Resolve-Path -LiteralPath 'P:\\tmp\\ag-context-tests').Path; if ($target -ne 'P:\\tmp\\ag-context-tests') { throw \"Unexpected cleanup target: $target\" }; Remove-Item -LiteralPath $target -Recurse -Force -ErrorAction Stop; \"removed=$target\""], decision="allow")
