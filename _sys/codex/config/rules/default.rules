prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$env:TEMP='P:\\tmp\\ag-context-tests'; $env:TMP='P:\\tmp\\ag-context-tests'; $env:PYTHONDONTWRITEBYTECODE='1'; python -m pytest _sys/tests/unit/test_hub_collaboration.py _sys/tests/unit/test_hub_peer.py -q -p no:cacheprovider"], decision="allow")
