prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$prompt='IPC DEBATE ONLY. Do not use tools or prior context. Decide whether AG alone should receive special context filtering, or whether every peer IPC call should use the same explicit context modes: isolated, room_compact, room_full. Separate IPC from interactive startup and separate session reuse from prompt context. Give arguments, AG-specific caveats, and final verdict in under 800 words.'; python -c \"import os,sys; sys.path.insert(0,r'P:\\_sys\\core'); import hub; out,elapsed=hub._ask_with_pty([r'P:\\_sys\\tools\\agy\\agy.exe','--dangerously-skip-permissions','-p',sys.argv[1],'--print-timeout','3m','--model','Gemini 3.1 Pro (High)'],'ag-direct',210,{**os.environ,'PYTHONUTF8':'1'},quiet=True); print(out)\" $prompt"], decision="allow")
prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$prompt='Final architecture cross-examination. AG agrees that IPC context policy should be uniform across peers, with isolated, room_compact, and room_full modes. It proposes AG may implement room_full through file pointers rather than raw text. Decide: (1) default mode for ordinary hub ask, (2) whether delivery may differ by peer while semantic evidence must remain equivalent, (3) exact constraints coupling isolated mode to fresh/reused sessions, (4) whether ACTIVE_THREADS belongs in compact mode given transport telemetry pollution, and (5) whether room phase may affect defaults. Do not inspect files or use tools. Return a concise final policy and strongest objection.'; & 'P:\\_sys\\env\\nodejs\\npm-global\\codex.cmd' exec $prompt --json --ephemeral --ignore-rules -s workspace-write --model gpt-5.5 -c 'model_reasoning_effort=\"high\"'"], decision="allow")
prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "$targets = Get-ChildItem -LiteralPath 'P:\\' -File -Force | Where-Object { $_.Name -match '^[A-Za-z0-9_]{6,}$' -and $_.Length -eq 4 -and (Get-Content -LiteralPath $_.FullName -Raw) -eq 'blat' }; $count = $targets.Count; $targets | Remove-Item -Force -ErrorAction Stop; \"removed=$count\""], decision="allow")
prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "Remove-Item -LiteralPath 'P:\\_sys\\ai\\ask_history.jsonl','P:\\_sys\\ai\\leases.json','P:\\_sys\\ai\\routing_metrics.jsonl' -Force -ErrorAction Stop; 'removed=3'"], decision="allow")
prefix_rule(pattern=["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command", "git add -- _sys/claude/config/settings.json _sys/codex/config/rules/default.rules && git commit -m \"Cleanup runtime junk and refresh config\""], decision="allow")
